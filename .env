# ============================================================
# Variables de entorno — copiar este archivo como .env
# En Railway: configurar estas mismas variables en el panel
#   Project → Variables → New Variable
# ============================================================

# URL del proyecto en Supabase (Settings → API → Project URL)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave de Supabase (Settings → API → anon/public key)
SUPABASE_KEY=tu_anon_key_aqui

# Puerto (Railway lo asigna automáticamente, no es necesario en producción)
PORT=3000

# URL base del servidor (para la documentación Swagger)
BASE_URL=http://localhost:3000
